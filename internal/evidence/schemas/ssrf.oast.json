{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ssrf.oast",
  "description": "SSRF proven by a server-side OAST callback after the app fetches a URL you control.",
  "x-flags": "-oast (+ -internal for loopback/private targets)",
  "x-notes": [
    "injection_location (NOT mutation_slots): { kind: \"query\", name: \"<param>\" }, { kind: \"json_body\", json_pointer: \"/a/b\" }, or { kind: \"header\", name: \"X-Forwarded-Host\" }.",
    "The placeholder at the injection location is overwritten, but must exist (a real query param / JSON field / declared header).",
    "header injection targets Host / X-Forwarded-Host SSRF: the engine plants the scheme-stripped callback authority (host[:port]/cb/<id>), since such sinks build scheme://<header>. Do NOT inline credential headers (Cookie/Authorization) — those are rejected.",
    "expected_protocols (e.g. [\"http\"], [\"dns\"]) filters which callbacks count. Set require_source_not_verifier true."
  ],
  "type": "object",
  "additionalProperties": false,
  "required": ["finding_id", "type", "target", "evidence", "proof"],
  "properties": {
    "finding_id": { "type": "string", "minLength": 1 },
    "type": { "const": "ssrf.oast" },
    "target": { "$ref": "#/$defs/target" },
    "auth": { "$ref": "#/$defs/auth" },
    "controls": { "type": "array", "items": { "$ref": "#/$defs/request" } },
    "mutation_slots": { "$ref": "#/$defs/mutation_slots" },
    "side_effects": { "$ref": "#/$defs/side_effects" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request", "injection_location"],
      "properties": {
        "request": { "$ref": "#/$defs/request" },
        "injection_location": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "enum": ["query", "json_body", "header"] },
            "name": { "type": "string", "description": "query parameter name (kind=query) or header name (kind=header)" },
            "json_pointer": { "type": "string", "description": "RFC-6901 pointer into the JSON body (kind=json_body)" }
          }
        },
        "expected_protocols": { "type": "array", "items": { "type": "string" } },
        "via_redirect": {
          "type": "boolean",
          "default": false,
          "x-note": "When true the engine injects a 302-redirector URL instead of the direct callback. Proves the target followed an attacker-controlled 30x redirect past first-hop host validation (e.g. postiz #368, typebot #440, langfuse #22/#25)."
        }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_signal", "poll_window_seconds"],
      "properties": {
        "expected_signal": { "type": "string", "description": "e.g. oast_interaction" },
        "poll_window_seconds": { "type": "number" },
        "require_source_not_verifier": { "type": "boolean" }
      }
    }
  },
  "examples": [
    {
      "finding_id": "ssrf-fetch-url",
      "type": "ssrf.oast",
      "target": {
        "expected_origin": "http://127.0.0.1:8080",
        "allowed_hosts": ["127.0.0.1"],
        "allowed_schemes": ["http"],
        "allowed_ports": [8080]
      },
      "auth": { "required": false },
      "evidence": {
        "request": {
          "method": "GET",
          "url": "http://127.0.0.1:8080/proxy?url=http%3A%2F%2Fplaceholder.invalid"
        },
        "injection_location": { "kind": "query", "name": "url" },
        "expected_protocols": ["http"]
      },
      "proof": {
        "expected_signal": "oast_interaction",
        "poll_window_seconds": 30,
        "require_source_not_verifier": true
      }
    },
    {
      "finding_id": "ssrf-xforwarded-host",
      "type": "ssrf.oast",
      "target": {
        "expected_origin": "http://127.0.0.1:8090",
        "allowed_hosts": ["127.0.0.1"],
        "allowed_schemes": ["http"],
        "allowed_ports": [8090]
      },
      "auth": { "required": false },
      "evidence": {
        "request": {
          "method": "GET",
          "url": "http://127.0.0.1:8090/setup/prereq-check",
          "headers": [{ "name": "X-Forwarded-Host", "value": "placeholder.invalid" }]
        },
        "injection_location": { "kind": "header", "name": "X-Forwarded-Host" },
        "expected_protocols": ["http"]
      },
      "proof": {
        "expected_signal": "oast_interaction",
        "poll_window_seconds": 30,
        "require_source_not_verifier": true
      }
    },
    {
      "finding_id": "ssrf-redirect-follow",
      "type": "ssrf.oast",
      "target": {
        "expected_origin": "http://127.0.0.1:8092",
        "allowed_hosts": ["127.0.0.1"],
        "allowed_schemes": ["http"],
        "allowed_ports": [8092]
      },
      "auth": { "required": false },
      "evidence": {
        "request": {
          "method": "POST",
          "url": "http://127.0.0.1:8092/fetch",
          "headers": [{ "name": "content-type", "value": "application/json" }],
          "body": "{\"url\":\"https://placeholder.example.com\"}"
        },
        "injection_location": { "kind": "json_body", "json_pointer": "/url" },
        "expected_protocols": ["http"],
        "via_redirect": true
      },
      "proof": {
        "expected_signal": "oast_interaction",
        "poll_window_seconds": 30,
        "require_source_not_verifier": true
      }
    }
  ]
}
