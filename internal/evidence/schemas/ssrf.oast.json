{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ssrf.oast",
  "description": "SSRF proven by a server-side OAST callback after the app fetches a URL you control.",
  "x-flags": "-oast (+ -internal for loopback/private targets)",
  "x-notes": [
    "injection_location (NOT mutation_slots): { kind: \"query\", name: \"<param>\" } or { kind: \"json_body\", json_pointer: \"/a/b\" }.",
    "The placeholder at the injection location is overwritten, but must exist (a real query param / JSON field).",
    "expected_protocols (e.g. [\"http\"], [\"dns\"]) filters which callbacks count. Set require_source_not_verifier true."
  ],
  "type": "object",
  "additionalProperties": false,
  "required": ["finding_id", "type", "target", "evidence", "proof"],
  "properties": {
    "finding_id": { "type": "string", "minLength": 1 },
    "type": { "const": "ssrf.oast" },
    "target": { "$ref": "#/$defs/target" },
    "auth": { "$ref": "#/$defs/auth" },
    "controls": { "type": "array", "items": { "$ref": "#/$defs/request" } },
    "mutation_slots": { "$ref": "#/$defs/mutation_slots" },
    "side_effects": { "$ref": "#/$defs/side_effects" },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request", "injection_location"],
      "properties": {
        "request": { "$ref": "#/$defs/request" },
        "injection_location": {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind"],
          "properties": {
            "kind": { "enum": ["query", "json_body"] },
            "name": { "type": "string", "description": "query parameter name (kind=query)" },
            "json_pointer": { "type": "string", "description": "RFC-6901 pointer into the JSON body (kind=json_body)" }
          }
        },
        "expected_protocols": { "type": "array", "items": { "type": "string" } }
      }
    },
    "proof": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected_signal", "poll_window_seconds"],
      "properties": {
        "expected_signal": { "type": "string", "description": "e.g. oast_interaction" },
        "poll_window_seconds": { "type": "number" },
        "require_source_not_verifier": { "type": "boolean" }
      }
    }
  },
  "examples": [
    {
      "finding_id": "ssrf-fetch-url",
      "type": "ssrf.oast",
      "target": {
        "expected_origin": "http://127.0.0.1:8080",
        "allowed_hosts": ["127.0.0.1"],
        "allowed_schemes": ["http"],
        "allowed_ports": [8080]
      },
      "auth": { "required": false },
      "evidence": {
        "request": {
          "method": "GET",
          "url": "http://127.0.0.1:8080/proxy?url=http%3A%2F%2Fplaceholder.invalid"
        },
        "injection_location": { "kind": "query", "name": "url" },
        "expected_protocols": ["http"]
      },
      "proof": {
        "expected_signal": "oast_interaction",
        "poll_window_seconds": 30,
        "require_source_not_verifier": true
      }
    }
  ]
}
