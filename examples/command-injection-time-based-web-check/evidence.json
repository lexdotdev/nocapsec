        "delay_low": "http://127.0.0.1/?x=\";sleep 0;\"",
        "delay_high": "http://127.0.0.1/?x=\";sleep 5;\""
      }
    }
  },
  "proof": {
    "repetitions": 4,
    "min_median_delta_ms": 3500,
    "require_body_similarity": true
  }
