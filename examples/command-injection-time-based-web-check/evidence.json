{
  "finding_id": "GHSA-5qg5-g7c2-pfx8",
  "type": "command_injection.time_based",
  "target": {
    "expected_origin": "http://127.0.0.1:3009",
    "allowed_hosts": ["127.0.0.1"],
    "allowed_schemes": ["http"],
    "allowed_ports": [3009]
  },
  "auth": {
    "required": false
  },
  "evidence": {
    "base_request": {
      "method": "GET",
      "url": "http://127.0.0.1:3009/api/screenshot?url=http://127.0.0.1/"
    },
    "injection": {
      "location": {
        "kind": "query",
        "name": "url"
